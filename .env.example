# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (ห้าม commit .env)
# Copy this file to .env and fill real values (never commit .env)

# Database (Prisma) — PostgreSQL
# DATABASE_URL = connection ที่แอปใช้ (runtime). prod/serverless ใช้ pooled (Neon: host มี -pooler)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/signage_dev?schema=public"

# DIRECT_DATABASE_URL = connection ตรง (unpooled) สำหรับ Prisma Migrate/CLI เท่านั้น
# local: เว้นว่างได้ (จะ fallback ไปใช้ DATABASE_URL). Neon prod: ใส่ host ที่ "ไม่มี" -pooler
# DIRECT_DATABASE_URL="postgresql://...neon.tech/db?sslmode=require"

# Auth.js v5 — สร้างด้วย: npx auth secret  (จำเป็นทั้ง dev และ prod)
# บน Vercel: ตั้ง AUTH_SECRET เป็น env var; ไม่ต้องตั้ง AUTH_URL/trustHost (auto)
AUTH_SECRET=""
